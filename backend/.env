SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
DATABASE_URL=sqlite:///./pcos_tracker.db

# Model Configuration
MODEL_TYPE=ollama_base
# Options: ollama_base, ollama_finetuned, lora_pipeline

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_BASE_MODEL=pcos-base
OLLAMA_FINETUNED_MODEL=pcos-llama3

# LoRA Configuration (if using lora_pipeline)
LORA_BASE_MODEL=meta-llama/Meta-Llama-3-8B-Instruct
LORA_ADAPTER_PATH=./models/pcos-llama3-lora

# Chat Configuration
MAX_CHAT_HISTORY=50
MAX_RESPONSE_LENGTH=512

# OTP/Email Configuration
OTP_ENABLED=true
EMAIL_BACKEND=smtp
# Options: console (development - shows in terminal) or smtp (production - sends real emails)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=ovula2025@gmail.com
SMTP_PASSWORD=hnqzfgwfzfxsuton
FROM_EMAIL=ovula2025@gmail.com
APP_NAME=Ovula
APP_URL=http://localhost:3000
