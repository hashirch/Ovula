# ── Copy this file to .env and fill in your values ──────────────────────────

# Auth
SECRET_KEY=change-this-to-a-random-64-char-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database (SQLite for local, PostgreSQL auto-set by Render on cloud)
DATABASE_URL=sqlite:///./pcos_tracker.db

# AI Model — set to openai_api to use Groq (free cloud LLM)
# For local dev with Ollama: MODEL_TYPE=ollama_base
MODEL_TYPE=openai_api

# Groq (free) — get key at https://console.groq.com
OPENAI_API_KEY=your-groq-api-key-here
OPENAI_MODEL=llama3-8b-8192
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Ollama (local dev only)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_BASE_MODEL=llama3

# Chat
MAX_CHAT_HISTORY=50
MAX_RESPONSE_LENGTH=512

# Email / OTP
OTP_ENABLED=true
EMAIL_BACKEND=smtp
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=your-email@gmail.com
APP_NAME=Ovula
APP_URL=http://localhost:3000

# ElevenLabs TTS (optional)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
