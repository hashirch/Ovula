# Backend Environment Variables Template
# Copy this to src/backend/.env and fill in your values

# ============================================================================
# SECURITY (Required)
# ============================================================================
SECRET_KEY=your-super-secret-key-change-this-min-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================================================
# DATABASE (Required)
# ============================================================================
# Local development (SQLite)
DATABASE_URL=sqlite:///./pcos_tracker.db

# Production (PostgreSQL - Railway provides this automatically)
# DATABASE_URL=postgresql://user:password@host:port/database

# ============================================================================
# LLM CONFIGURATION (Required - Choose ONE)
# ============================================================================

# Option 1: Groq API (Recommended for deployment - FREE)
MODEL_TYPE=groq_api
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.1-70b-versatile

# Option 2: Local Ollama (For development)
# MODEL_TYPE=ollama_base
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_BASE_MODEL=llama3
# OLLAMA_FINETUNED_MODEL=pcos-llama3

# Option 3: OpenAI API (Paid)
# MODEL_TYPE=openai_api
# OPENAI_API_KEY=sk-your-openai-key
# OPENAI_MODEL=gpt-3.5-turbo

# ============================================================================
# EMAIL / OTP (Required for user verification)
# ============================================================================
OTP_ENABLED=true
EMAIL_BACKEND=smtp
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
FROM_EMAIL=your-email@gmail.com
APP_NAME=Ovula
APP_URL=http://localhost:3000

# ============================================================================
# CHAT CONFIGURATION (Optional - defaults provided)
# ============================================================================
MAX_CHAT_HISTORY=50
MAX_RESPONSE_LENGTH=512

# ============================================================================
# ELEVENLABS TTS (Optional - for voice features)
# ============================================================================
ELEVENLABS_API_KEY=your-elevenlabs-key
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# ============================================================================
# NOTES
# ============================================================================
# 
# 1. SECRET_KEY: Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# 
# 2. GROQ_API_KEY: Get free key from https://console.groq.com/
# 
# 3. Gmail App Password:
#    - Enable 2FA on your Gmail account
#    - Go to Google Account → Security → App Passwords
#    - Generate password for "Mail"
#    - Use the 16-character password as SMTP_PASSWORD
# 
# 4. For production deployment:
#    - Use strong SECRET_KEY (min 32 characters)
#    - Use PostgreSQL instead of SQLite
#    - Set APP_URL to your frontend URL
#    - Never commit .env file to git
# 
# ============================================================================
